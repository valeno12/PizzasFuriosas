# JWT
JWT_KEY=your_super_secret_key_here_make_it_long
JWT_ISSUER=PizzasFuriosas.Api
JWT_AUDIENCE=PizzasFuriosas.Client
JWT_EXPIRATION_HOURS=720

# CORS
# Separar multiples origenes con coma o punto y coma. No incluir slash final.
CORS_ALLOWED_ORIGINS=https://pizzasfuriosas-admin.pages.dev,https://pizzasfuriosas.pages.dev

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ADMIN SEED
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=your_secure_password
# Base de datos (opcional): URL de Postgres estilo hosting gratuito (Neon/Supabase/Render).
# Si no se define, se usa ConnectionStrings:DefaultConnection de appsettings.json (docker-compose local).
# DATABASE_URL=postgres://usuario:password@host:5432/pizzasfuriosas
