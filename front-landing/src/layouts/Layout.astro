---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = 'Pizza Furiosa · Pizza a la piedra en Paraná' } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <meta
      name="description"
      content="Pizza Furiosa — masa de fermentación lenta y horno a pura llama en Paraná. Armá tu pedido y lo cerramos por WhatsApp."
    />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat+Brush&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
