---
import { BUSINESS, EVENT_WHATSAPP_URL } from '../config'
---

<section class="info" id="horarios">
  <div class="container info-layout">
    <div>
      <h2 class="brush">Horarios y zona</h2>
      <div class="info-list">
        <div class="info-item">
          <div class="info-icon">01</div>
          <div>
            <strong>{BUSINESS.days}</strong>
            <span>Horario según la tanda del día</span>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">02</div>
          <div>
            <strong>{BUSINESS.city}</strong>
            <span>Consultá si llegamos a tu zona</span>
          </div>
        </div>
        <div class="info-item">
          <div class="info-icon">03</div>
          <div>
            <strong>Para compartir</strong>
            <span>La pizza del finde</span>
          </div>
        </div>
      </div>
      <div class="info-actions">
        <a class="btn btn-primary" href="#pedido">Armar pedido</a>
        <a class="btn btn-outline" href="#carta">Volver a la carta</a>
      </div>
    </div>
    <div class="event-card">
      <img class="photo" src="/images/IMG_20260616_130329.webp" alt="Pizzas a la piedra saliendo del horno a la llama" loading="lazy" />
      <p class="brush title">¿Tenés un evento?</p>
      <p>Llevamos las pizzas a donde estés. Escribinos al {BUSINESS.phoneDisplay}.</p>
      <a class="event-cta" href={EVENT_WHATSAPP_URL} target="_blank" rel="noopener">Consultar evento</a>
    </div>
  </div>
</section>
