---
// Capturas reales de WhatsApp (prueba social). Los archivos ya vienen con el texto quemado.
const messages = [
  '/SaveClip.App_503498941_18063722015274201_1203700734263063249_n.jpg',
  '/SaveClip.App_503582086_18063722033274201_3037736954583845716_n.jpg',
  '/SaveClip.App_502339055_18063722024274201_1880509447429888319_n.jpg',
  '/SaveClip.App_731808324_18102074504274201_5316625905645456420_n.jpg',
  '/SaveClip.App_726838772_18101064803274201_6562814541515865771_n.jpg',
]
---

<section class="favorites">
  <div class="container">
    <h2 class="brush">Las favoritas de la gente</h2>
    <div class="message-wall">
      {
        messages.map((src) => (
          <figure class="message-card">
            <img src={src} alt="Mensaje de un cliente sobre Pizza Furiosa" loading="lazy" />
          </figure>
        ))
      }
    </div>
  </div>
</section>
